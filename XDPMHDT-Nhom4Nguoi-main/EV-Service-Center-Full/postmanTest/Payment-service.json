  "item": [
    {
      "name": "Create Payment - Success",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "const res = pm.response.json();\r",
              "\r",
              "pm.test(\"Response has required fields\", function () {\r",
              "    pm.expect(res.id).to.exist;\r",
              "    pm.expect(res.invoice_id).to.exist;\r",
              "    pm.expect(res.user_id).to.exist;\r",
              "    pm.expect(res.amount).to.exist;\r",
              "    pm.expect(res.method).to.exist;\r",
              "    pm.expect(res.pg_transaction_id).to.exist;\r",
              "    pm.expect(res.status).to.exist;\r",
              "});\r",
              "\r",
              "pm.test(\"Payment status is pending\", function () {\r",
              "    pm.expect(String(res.status)).to.include(\"pending\");\r",
              "});\r",
              "\r",
              "pm.environment.set(\"payment_id\", res.id);\r",
              "pm.environment.set(\"pg_transaction_id\", res.pg_transaction_id);\r",
              "pm.environment.set(\"payment_status\", res.status);\r",
              "\r",
              "if (res.payment_data) {\r",
              "    pm.collectionVariables.set(\"payment_data\", res.payment_data);\r",
              "}\r",
              "\r",
              "pm.test(\"pg_transaction_id saved\", function () {\r",
              "    pm.expect(pm.environment.get(\"pg_transaction_id\")).to.exist;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"invoice_id\": {{invoice_id}},\r\n  \"method\": \"{{payment_method}}\",\r\n  \"user_id\": {{user_id}},\r\n  \"amount\": {{payment_amount}}\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url_payment}}/api/payments/create",
          "host": [
            "{{base_url_payment}}"
          ],
          "path": [
            "api",
            "payments",
            "create"
          ]
        }
      },
      "response": []
    },
