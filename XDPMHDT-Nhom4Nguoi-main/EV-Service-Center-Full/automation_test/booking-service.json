    {
      "name": "Get Booking By ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code valid\", function () {\r",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 401, 403, 404]);\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "\r",
              "if (pm.response.code === 200) {\r",
              "    pm.test(\"Booking id matches\", function () {\r",
              "        pm.expect(jsonData.id).to.eql(Number(pm.environment.get(\"booking_id\")));\r",
              "    });\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
