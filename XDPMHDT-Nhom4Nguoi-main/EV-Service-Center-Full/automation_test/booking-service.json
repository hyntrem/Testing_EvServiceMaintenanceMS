        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let jsonData;\r",
                  "try {\r",
                  "    jsonData = pm.response.json();\r",
                  "} catch (e) {\r",
                  "    throw new Error(\"Response is not valid JSON\");\r",
                  "}\r",
                  "\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"access_token exists\", function () {\r",
                  "    pm.expect(jsonData.access_token).to.exist;\r",
                  "});\r",
                  "\r",
                  "pm.environment.set(\"token\", jsonData.access_token);\r",
                  "\r",
                  "console.log(\"Login response:\", jsonData);\r",
                  "console.log(\"Saved token:\", pm.environment.get(\"token\"));"
