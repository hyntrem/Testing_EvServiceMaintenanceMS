    {
      "name": "Create Booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code valid\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201, 400, 401, 403]);",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "",
              "if (pm.response.code === 200 || pm.response.code === 201) {",
              "    pm.test(\"Booking exists\", function () {",
              "        pm.expect(jsonData.booking).to.exist;",
              "        pm.expect(jsonData.booking.id).to.exist;",
              "    });",
              "",
              "    pm.environment.set(\"booking_id\", jsonData.booking.id);",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
