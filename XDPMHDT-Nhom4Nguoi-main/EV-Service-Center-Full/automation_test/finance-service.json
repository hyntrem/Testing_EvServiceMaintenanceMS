{
  "info": {
    "_postman_id": "47b51197-4a78-4835-a596-6d872c0256aa",
    "name": "finance-service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "49736195"
  },
  "item": [
    {
      "name": "Create Invoice (ADMIN) (Tạo hóa đơn)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let json = pm.response.json();\r",
              "\r",
              "if (pm.response.code === 201) {\r",
              "    pm.environment.set(\"invoice_id\", json.invoice.invoice_id);\r",
              "}\r",
              "\r",
              "pm.test(\"Invoice created or already exists\", function () {\r",
              "    pm.expect([201,409]).to.include(pm.response.code);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"booking_id\": {{booking_id}}\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/invoices/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "invoices",
            ""
          ]
        }
      },
      "response": []
    },
    {
      "name": "Initiate Payment (Finance → Payment)(Khởi tạo thanh toán)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let json = pm.response.json();\r",
              "\r",
              "pm.environment.set(\r",
              "    \"pg_transaction_id\",\r",
              "    json.transaction.pg_transaction_id\r",
              ");\r",
              "\r",
              "pm.test(\"Payment initiated\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"method\": \"bank_transfer\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/invoices/{{invoice_id}}/pay",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "invoices",
            "{{invoice_id}}",
            "pay"
          ]
        }
      },
      "response": []
    }
  ]
}