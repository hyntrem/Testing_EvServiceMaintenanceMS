    {
      "name": "Get Item By ID",
      "item": [
        {
          "name": "Get by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Kiểm tra Status Code\r",
                  "pm.test(\"Status 200\", () => {\r",
                  "    pm.expect(pm.response.code).to.eql(200);\r",
                  "});\r",
                  "\r",
                  "const res = pm.response.json();\r",
                  "\r",
                  "// 2. Kiểm tra cấu trúc Response & Kiểu dữ liệu (Đáp ứng Task 1)\r",
                  "pm.test(\"Item has all required fields and correct types\", () => {\r",
                  "    pm.expect(res).to.have.property(\"id\");\r",
                  "    pm.expect(res).to.have.property(\"name\");\r",
                  "    pm.expect(res).to.have.property(\"part_number\");\r",
                  "    \r",
                  "    // Kiểm tra phải là số để phục vụ tính toán Task 4\r",
                  "    pm.expect(res.quantity).to.be.a('number'); \r",
                  "    pm.expect(res.price).to.be.a('number');\r",
                  "});\r",
                  "\r",
                  "// 3. LƯU BIẾN CHO TASK 3 & TASK 4\r",
                  "if (res.id) {\r",
                  "    pm.environment.set(\"item_id\", res.id);\r",
                  "}\r",
                  "\r",
                  "if (res.quantity !== undefined) {\r",
                  "    pm.environment.set(\"old_quantity\", res.quantity);\r",
                  "    \r",
                  "    // GIẢ LẬP FINANCE \r",
                  "    // Thiết lập số lượng Finance muốn trừ (ví dụ mua 5 cái)\r",
                  "    let order_amount = 5; \r",
                  "    pm.environment.set(\"order_amount\", order_amount);\r",
                  "    \r",
                  "    // Tính toán số lượng dự kiến còn lại sau khi trừ thành công\r",
                  "    pm.environment.set(\"expected_after_success\", res.quantity - order_amount);\r",
                  "    \r",
                  "    // Tính toán một con số gây thiếu hàng (ví dụ hiện có 5, đòi trừ 100)\r",
                  "    pm.environment.set(\"over_order_amount\", res.quantity + 100);\r",
                  "}\r",
                  "\r",
                  "// 4. Kiểm tra logic min_quantity \r",
                  "if (res.quantity <= res.min_quantity) {\r",
                  "    console.warn(`[WARNING] Item ${res.id} is LOW STOCK! (Qty: ${res.quantity} <= Min: ${res.min_quantity})`);\r",
                  "}\r",
                  "\r",
                  "console.log(\"--- BẢN TIN INTEGRATION TASK 4 ---\");\r",
                  "console.log(\"ID đang dùng:\", pm.environment.get(\"item_id\"));\r",
                  "console.log(\"Tồn kho hiện tại:\", pm.environment.get(\"old_quantity\"));\r",
                  "console.log(\"Số lượng Finance sẽ trừ:\", pm.environment.get(\"order_amount\"));"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
