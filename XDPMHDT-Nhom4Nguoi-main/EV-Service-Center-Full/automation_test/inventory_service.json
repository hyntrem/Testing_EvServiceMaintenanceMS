          "name": "Update success",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Kiểm tra Status Code\r",
                  "pm.test(\"Status 200 or 204\", () => {\r",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 204]);\r",
                  "});\r",
                  "\r",
                  "const res = pm.response.json();\r",
                  "const oldQty = Number(pm.environment.get(\"old_quantity\"));\r",
                  "\r",
                  "// Giả sử trong Body bạn gửi quantity mới là một số cụ thể, ví dụ: 40\r",
                  "// Hoặc bạn có thể lấy trực tiếp từ request body nếu dùng biến\r",
                  "const sentQty = JSON.parse(pm.request.body.raw).quantity;\r",
                  "\r",
                  "pm.test(\"Validate Stock Logic: Quantity updated correctly\", () => {\r",
                  "    if (res.item) {\r",
                  "        // Kiểm tra xem số lượng mới có đúng bằng số lượng bạn vừa gửi không\r",
                  "        pm.expect(res.item.quantity).to.eql(sentQty);\r",
                  "        \r",
                  "        // Tính toán độ chênh lệch để log ra cho rõ ràng (Dành cho Integration Test)\r",
                  "        const diff = oldQty - res.item.quantity;\r",
                  "        console.log(`Số lượng giảm đi: ${diff} đơn vị (Từ ${oldQty} xuống ${res.item.quantity})`);\r",
                  "    }\r",
                  "});\r",
                  "\r",
                  "// 2. Validate Structure (Task 1)\r",
                  "pm.test(\"Update response has required fields\", () => {\r",
                  "    if (res.item) {\r",
                  "        pm.expect(res.item).to.have.property(\"part_number\");\r",
                  "        pm.expect(res.item).to.have.property(\"price\");\r",
                  "    }\r",
                  "});\r",
                  "\r",
                  "console.log(\"Update success & Quantity validated\");"
                ],
