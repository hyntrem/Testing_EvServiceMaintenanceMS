                  "pm.test(\"Status code is 201 or 409\", function () {\r",
                  "    pm.expect([201, 409]).to.include(pm.response.code);\r",
                  "});\r",
                  "\r",
                  "if (pm.response.code === 201) {\r",
                  "\r",
                  "    let jsonData = pm.response.json();\r",
                  "\r",
                  "    pm.test(\"Item created successfully\", function () {\r",
                  "        pm.expect(jsonData).to.have.property(\"item\");\r",
                  "        pm.expect(jsonData.item).to.have.property(\"id\");\r",
                  "        pm.expect(jsonData.item).to.have.property(\"name\");\r",
                  "    });\r",
                  "\r",
                  "    pm.environment.set(\"item_id\", jsonData.item.id);\r",
                  "}\r",
                  ""
