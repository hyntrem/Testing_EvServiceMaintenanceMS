        {
          "name": "GET Inventory Item",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let jsonData = pm.response.json();\r",
                  "\r",
                  "console.log(\"GET Response:\", jsonData);\r",
                  "console.log(\"Saved ID:\", pm.environment.get(\"item_id\"));\r",
                  "\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time < 2s\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response is JSON\", function () {\r",
                  "    pm.response.to.be.json;\r",
                  "});\r",
                  "\r",
                  "// 🔥 lấy ID đúng cách (chống lỗi)\r",
                  "let id;\r",
                  "\r",
                  "if (jsonData.item && jsonData.item.id !== undefined) {\r",
                  "    id = jsonData.item.id;\r",
                  "} \r",
                  "else if (Array.isArray(jsonData)) {\r",
                  "    id = jsonData[0]?.id;\r",
                  "} \r",
                  "else {\r",
                  "    id = jsonData.id;\r",
                  "}\r",
                  "\r",
                  "pm.test(\"Correct item returned\", function () {\r",
                  "    pm.expect(id).to.not.be.undefined;\r",
                  "    pm.expect(id).to.eql(parseInt(pm.environment.get(\"item_id\")));\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{url_base}}/api/inventory/items",
              "host": [
                "{{url_base}}"
              ],
              "path": [
                "api",
                "inventory",
                "items"
              ]
            }
          },
          "response": []
        },
