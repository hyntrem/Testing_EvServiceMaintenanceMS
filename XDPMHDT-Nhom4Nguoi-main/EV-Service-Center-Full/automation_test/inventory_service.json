      "name": "Low Stock",
      "item": [
        {
          "name": "Low Stock",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Lấy dữ liệu trả về từ Server (thường là một danh sách các món hàng)\r",
                  "const res = pm.response.json();\r",
                  "\r",
                  "// 2. Kiểm tra xem Server có trả về đúng định dạng danh sách (Mảng) không\r",
                  "pm.test(\"Dữ liệu trả về phải là một danh sách (Array)\", () => {\r",
                  "    pm.expect(res).to.be.an(\"array\");\r",
                  "});\r",
                  "\r",
                  "// 3. Kiểm tra logic nghiệp vụ: TẤT CẢ hàng trong này phải có số lượng thấp\r",
                  "pm.test(\"Logic Check: Tất cả các mục phải có Quantity <= Min_Quantity\", () => {\r",
                  "    // Duyệt qua từng món hàng (item) trong danh sách trả về\r",
                  "    res.forEach(item => {\r",
                  "        const qty = Number(item.quantity);\r",
                  "        const minQty = Number(item.min_quantity);\r",
                  "        \r",
                  "        // Đây là lệnh kiểm tra quan trọng nhất:\r",
                  "        // Kỳ vọng qty phải \"At most\" (nhỏ hơn hoặc bằng) minQty\r",
                  "        pm.expect(qty).to.be.at.most(minQty, \r",
                  "            `Lỗi logic tại Item ID ${item.id}: Tồn kho là ${qty} nhưng hạn mức là ${minQty}. Lẽ ra không được nằm trong danh sách Low Stock!`);\r",
                  "    });\r",
                  "});\r",
                  "\r",
                  "// 4. Kiểm tra xem Item bạn vừa Update ở Bước 2 có nằm trong danh sách này không\r",
                  "pm.test(\"Item vừa cập nhật phải xuất hiện trong danh sách Low Stock\", () => {\r",
                  "    const targetId = pm.environment.get(\"item_id\");\r",
                  "    // Tìm trong danh sách xem có ID nào trùng với ID mình vừa update không\r",
                  "    const found = res.find(item => item.id == targetId);\r",
                  "    pm.expect(found).to.not.be.undefined;\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
