  "item": [
    {
      "name": "Admin - Create Invoice",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Create invoice status code\", function () {\r",
              "    pm.expect(pm.response.code).to.be.oneOf([201, 400, 409, 401, 403]);\r",
              "});\r",
              "\r",
              "if (pm.response.code === 201) {\r",
              "    const jsonData = pm.response.json();\r",
              "\r",
              "    pm.test(\"Có message thành công\", function () {\r",
              "        pm.expect(jsonData.message).to.include(\"Hóa đơn được tạo\");\r",
              "    });\r",
              "\r",
              "    pm.test(\"Có invoice object\", function () {\r",
              "        pm.expect(jsonData.invoice).to.be.an(\"object\");\r",
              "        pm.expect(jsonData.invoice.id).to.exist;\r",
              "        pm.expect(jsonData.invoice.booking_id).to.exist;\r",
              "        pm.expect(jsonData.invoice.items).to.be.an(\"array\");\r",
              "    });\r",
              "\r",
              "    pm.environment.set(\"invoice_id\", jsonData.invoice.id);\r",
              "    pm.environment.set(\"created_invoice_status\", jsonData.invoice.status);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{jwt_admin}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_admin}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"booking_id\": {{booking_id}}\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/invoices/",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "invoices",
            ""
          ]
        }
      },
      "response": []
    },
    {
      "name": "Admin - Get All Invoices",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const data = pm.response.json();\r",
              "\r",
              "pm.test(\"Response là array\", function () {\r",
              "    pm.expect(data).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "if (data.length > 0) {\r",
              "    pm.environment.set(\"invoice_id\", data[0].id);\r",
              "\r",
              "    pm.test(\"Invoice có field cơ bản\", function () {\r",
              "        pm.expect(data[0]).to.have.property(\"id\");\r",
              "        pm.expect(data[0]).to.have.property(\"booking_id\");\r",
              "        pm.expect(data[0]).to.have.property(\"user_id\");\r",
              "        pm.expect(data[0]).to.have.property(\"status\");\r",
              "        pm.expect(data[0]).to.have.property(\"total_amount\");\r",
              "    });\r",
              "}"
            ],
