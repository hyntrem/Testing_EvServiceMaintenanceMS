    {
      "name": "Get Invoice Detail",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code hợp lệ\", function () {\r",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 401, 403, 404]);\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "\r",
              "if (pm.response.code === 200) {\r",
              "    pm.test(\"Có thông tin invoice detail\", function () {\r",
              "        pm.expect(jsonData.id).to.exist;\r",
              "        pm.expect(jsonData.booking_id).to.exist;\r",
              "        pm.expect(jsonData.user_id).to.exist;\r",
              "        pm.expect(jsonData.total_amount).to.exist;\r",
              "        pm.expect(jsonData.status).to.exist;\r",
              "        pm.expect(jsonData.items).to.be.an(\"array\");\r",
              "    });\r",
              "\r",
              "    pm.environment.set(\"invoice_id\", jsonData.id);\r",
              "\r",
              "    if (jsonData.status) {\r",
              "        pm.environment.set(\"current_invoice_status\", jsonData.status);\r",
              "    }\r",
              "} else {\r",
              "    console.log(\"Get Invoice Detail failed:\", jsonData);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
