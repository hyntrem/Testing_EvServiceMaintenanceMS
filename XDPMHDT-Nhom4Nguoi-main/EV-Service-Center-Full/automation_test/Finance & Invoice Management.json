    {
      "name": "Admin - Update Invoice Status",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code hợp lệ\", function () {\r",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 400, 401, 403, 404]);\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "\r",
              "if (pm.response.code === 200) {\r",
              "    pm.test(\"Update status thành công\", function () {\r",
              "        pm.expect(jsonData).to.have.property(\"invoice\");\r",
              "        pm.expect(jsonData.invoice).to.have.property(\"id\");\r",
              "        pm.expect(jsonData.invoice).to.have.property(\"status\");\r",
              "    });\r",
              "\r",
              "    pm.environment.set(\"current_invoice_status\", jsonData.invoice.status);\r",
              "\r",
              "    pm.test(\"Status đã được cập nhật đúng\", function () {\r",
              "        pm.expect(jsonData.invoice.status).to.eql(pm.environment.get(\"expected_status\"));\r",
              "    });\r",
              "} else {\r",
              "    console.log(\"Update Invoice Status failed:\", jsonData);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
