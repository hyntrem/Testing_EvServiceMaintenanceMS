  "item": [
    {
      "name": "Access Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code phải là 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// Parse JSON response\r",
              "let jsonData = pm.response.json();\r",
              "\r",
              "// Kiểm tra access_token tồn tại\r",
              "pm.test(\"Response phải có access_token\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"access_token\");\r",
              "});\r",
              "\r",
              "// Kiểm tra access_token là dạng string\r",
              "pm.test(\"access_token phải là string\", function () {\r",
              "    pm.expect(jsonData.access_token).to.be.a(\"string\");\r",
              "});\r",
              "\r",
              "// Kiểm tra token không rỗng\r",
              "pm.test(\"access_token không được rỗng\", function () {\r",
              "    pm.expect(jsonData.access_token.length).to.be.above(10);\r",
              "});\r",
              "\r",
              "// LƯU TOKEN VÀO ENVIRONMENT \r",
              "pm.environment.set(\"access_token\", jsonData.access_token);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
