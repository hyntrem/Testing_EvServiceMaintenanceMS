    {
      "name": "Revenue Report",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Lấy token từ environment\r",
              "const accessToken = pm.environment.get(\"access_token\");\r",
              "// Thêm token vào header Authorization\r",
              "pm.request.headers.add({\r",
              "    key: \"Authorization\",\r",
              "    value: `Bearer ${accessToken}`\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "let jsonData = pm.response.json();\r",
              "\r",
              "// Status code\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "//Check field tồn tại\r",
              "pm.test(\"Response có đầy đủ field\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"avg_transaction_value\");\r",
              "    pm.expect(jsonData).to.have.property(\"payment_methods\");\r",
              "    pm.expect(jsonData).to.have.property(\"period\");\r",
              "    pm.expect(jsonData).to.have.property(\"total_revenue\");\r",
              "    pm.expect(jsonData).to.have.property(\"transaction_count\");\r",
              "});\r",
              "\r",
              "//Kiểu dữ liệu\r",
              "pm.test(\"Data types correct\", function () {\r",
              "    pm.expect(jsonData.avg_transaction_value).to.be.a(\"number\");\r",
              "    pm.expect(jsonData.total_revenue).to.be.a(\"number\");\r",
              "    pm.expect(jsonData.transaction_count).to.be.a(\"number\");\r",
              "    pm.expect(jsonData.payment_methods).to.be.an(\"object\");\r",
              "    pm.expect(jsonData.period).to.be.an(\"object\");\r",
              "});\r",
              "\r",
              "// Period hợp lệ\r",
              "pm.test(\"Period có start_date và end_date\", function () {\r",
              "    pm.expect(jsonData.period).to.have.property(\"start_date\");\r",
              "    pm.expect(jsonData.period).to.have.property(\"end_date\");\r",
              "});\r",
              "\r",
              "//Logic thời gian\r",
              "pm.test(\"start_date <= end_date\", function () {\r",
              "    let start = new Date(jsonData.period.start_date);\r",
              "    let end = new Date(jsonData.period.end_date);\r",
              "\r",
              "    pm.expect(end >= start).to.be.true;\r",
              "});\r",
              "\r",
              "\r",
              "// Response time\r",
              "pm.test(\"Response time < 2s\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "method": "GET",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}{{url_prefix}}/revenue?start_date=2024-01-01&end_date=2024-01-31",
