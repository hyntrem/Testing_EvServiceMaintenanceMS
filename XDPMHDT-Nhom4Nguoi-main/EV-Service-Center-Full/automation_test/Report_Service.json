    {
      "name": "Dashboard",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Lấy token từ environment\r",
              "const accessToken = pm.environment.get(\"access_token\");\r",
              "// Thêm token vào header Authorization\r",
              "pm.request.headers.add({\r",
              "    key: \"Authorization\",\r",
              "    value: `Bearer ${accessToken}`\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const data = pm.response.json();\r",
              "\r",
              "pm.test(\"Response has main sections\", function () {\r",
              "    pm.expect(data).to.have.property(\"bookings\");\r",
              "    pm.expect(data).to.have.property(\"inventory\");\r",
              "    pm.expect(data).to.have.property(\"revenue\");\r",
              "    pm.expect(data).to.have.property(\"timestamp\");\r",
              "});\r",
              "\r",
              "//check có tồn tại k\r",
              "pm.test(\"Dashboard structure is valid\", function () {\r",
              "    pm.expect(data.bookings).to.be.an(\"object\");\r",
              "    pm.expect(data.inventory).to.be.an(\"object\");\r",
              "    pm.expect(data.revenue).to.be.an(\"object\");\r",
              "});\r",
              "//xem có dữ liệu trống k\r",
              "pm.test(\"Empty dashboard data\", function () {\r",
              "\r",
              "    // Bookings\r",
              "    pm.expect(data.bookings.total).to.eql(0);\r",
              "    pm.expect(data.bookings.completed).to.eql(0);\r",
              "    pm.expect(data.bookings.pending).to.eql(0);\r",
              "    pm.expect(data.bookings.confirmed).to.eql(0);\r",
              "\r",
              "    // Inventory\r",
              "    pm.expect(data.inventory.total_parts).to.eql(0);\r",
              "    pm.expect(data.inventory.total_quantity).to.eql(0);\r",
              "    pm.expect(data.inventory.total_inventory_value).to.eql(0);\r",
              "\r",
              "    // Revenue (month)\r",
              "    pm.expect(data.revenue.month.total_revenue).to.eql(0);\r",
              "    pm.expect(data.revenue.month.transaction_count).t\r",
              "    pm.expect(data.revenue.today.total_revenue).to.eql(0);\r",
              "    pm.expect(data.revenue.today.transaction_count).to.eql(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is acceptable\", function () {\r",
              "    const time = pm.response.responseTime;\r",
              "    pm.expect(time).to.be.below(2000); \r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
