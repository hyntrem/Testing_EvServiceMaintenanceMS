                  "    pm.expect(jsonData.access_token).to.be.a(\"string\");\r",
                  "});\r",
                  "\r",
                  "// Kiểm tra token không rỗng\r",
                  "pm.test(\"access_token không được rỗng\", function () {\r",
                  "    pm.expect(jsonData.access_token.length).to.be.above(10);\r",
                  "});"
