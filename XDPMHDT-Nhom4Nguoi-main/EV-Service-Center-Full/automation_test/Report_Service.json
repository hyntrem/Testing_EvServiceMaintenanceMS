    {
      "name": "Dashboard",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Lấy token từ environment\r",
              "const accessToken = pm.environment.get(\"access_token\");\r",
              "// Thêm token vào header Authorization\r",
              "pm.request.headers.add({\r",
              "    key: \"Authorization\",\r",
              "    value: `Bearer ${accessToken}`\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "let jsonData = pm.response.json();\r",
              "\r",
              "//Status code\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// =======================\r",
              "//BOOKINGS\r",
              "// =======================\r",
              "pm.test(\"Bookings structure đúng\", function () {\r",
              "    let b = jsonData.bookings;\r",
              "\r",
              "    pm.expect(b).to.have.property(\"completed\");\r",
              "    pm.expect(b).to.have.property(\"confirmed\");\r",
              "    pm.expect(b).to.have.property(\"pending\");\r",
              "    pm.expect(b).to.have.property(\"total\");\r",
              "});\r",
              "\r",
              "// Kiểu dữ liệu\r",
              "pm.test(\"Bookings data types\", function () {\r",
              "    let b = jsonData.bookings;\r",
              "\r",
              "    pm.expect(b.completed).to.be.a(\"number\");\r",
              "    pm.expect(b.confirmed).to.be.a(\"number\");\r",
              "    pm.expect(b.pending).to.be.a(\"number\");\r",
              "    pm.expect(b.total).to.be.a(\"number\");\r",
              "});\r",
              "\r",
              "// Logic \r",
              "pm.test(\"Bookings total = sum\", function () {\r",
              "    let b = jsonData.bookings;\r",
              "\r",
              "    pm.expect(b.total).to.eql(b.completed + b.confirmed + b.pending);\r",
              "});\r",
              "\r",
              "// =======================\r",
              "//INVENTORY\r",
              "// =======================\r",
              "let inv = jsonData.inventory;\r",
              "\r",
              "pm.test(\"Inventory structure đúng\", function () {\r",
              "    pm.expect(inv.low_stock_parts).to.be.an(\"array\");\r",
              "    pm.expect(inv.out_of_stock_parts).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "// Logic count = length\r",
              "pm.test(\"Inventory count đúng\", function () {\r",
              "    pm.expect(inv.low_stock_count).to.eql(inv.low_stock_parts.length);\r",
              "    pm.expect(inv.out_of_stock_count).to.eql(inv.out_of_stock_parts.length);\r",
              "});\r",
              "\r",
              "// =======================\r",
              "//REVENUE\r",
              "// =======================\r",
              "[\"today\", \"month\"].forEach(periodKey => {\r",
              "    let r = jsonData.revenue[periodKey];\r",
              "\r",
              "    pm.test(`Revenue ${periodKey} structure`, function () {\r",
              "        pm.expect(r).to.have.property(\"total_revenue\");\r",
              "        pm.expect(r).to.have.property(\"transaction_count\");\r",
              "        pm.expect(r).to.have.property(\"avg_transaction_value\");\r",
              "        pm.expect(r).to.have.property(\"payment_methods\");\r",
              "        pm.expect(r).to.have.property(\"period\");\r",
              "    });\r",
              "\r",
              "    // Kiểu dữ liệu\r",
              "    pm.test(`Revenue ${periodKey} types`, function () {\r",
              "        pm.expect(r.total_revenue).to.be.a(\"number\");\r",
              "        pm.expect(r.transaction_count).to.be.a(\"number\");\r",
              "        pm.expect(r.avg_transaction_value).to.be.a(\"number\");\r",
              "        pm.expect(r.payment_methods).to.be.an(\"object\");\r",
              "    });\r",
              "\r",
              "    // Check thời gian\r",
              "    pm.test(`Revenue ${periodKey} date hợp lệ`, function () {\r",
              "        let start = new Date(r.period.start_date);\r",
              "        let end = new Date(r.period.end_date);\r",
              "\r",
              "        pm.expect(end >= start).to.be.true;\r",
              "    });\r",
              "});\r",
              "\r",
              "// =======================\r",
              "// TIMESTAMP\r",
              "// =======================\r",
              "pm.test(\"Timestamp tồn tại\", function () {\r",
              "    pm.expect(jsonData.timestamp).to.exist;\r",
              "});\r",
              "\r",
              "// =======================\r",
              "// PERFORMANCE\r",
              "// =======================\r",
              "pm.test(\"Response time < 2s\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
