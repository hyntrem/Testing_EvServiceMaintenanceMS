    {
      "name": "Inventory Report",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Lấy token từ environment\r",
              "const accessToken = pm.environment.get(\"access_token\");\r",
              "// Thêm token vào header Authorization\r",
              "pm.request.headers.add({\r",
              "    key: \"Authorization\",\r",
              "    value: `Bearer ${accessToken}`\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "let jsonData = pm.response.json();\r",
              "\r",
              "//Status code\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "//Check field tồn tại\r",
              "pm.test(\"Có đầy đủ field\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"low_stock_count\");\r",
              "    pm.expect(jsonData).to.have.property(\"low_stock_parts\");\r",
              "    pm.expect(jsonData).to.have.property(\"out_of_stock_count\");\r",
              "    pm.expect(jsonData).to.have.property(\"out_of_stock_parts\");\r",
              "    pm.expect(jsonData).to.have.property(\"total_inventory_value\");\r",
              "    pm.expect(jsonData).to.have.property(\"total_parts\");\r",
              "    pm.expect(jsonData).to.have.property(\"total_quantity\");\r",
              "});\r",
              "\r",
              "//Kiểu dữ liệu\r",
              "pm.test(\"Data types đúng\", function () {\r",
              "    pm.expect(jsonData.low_stock_count).to.be.a(\"number\");\r",
              "    pm.expect(jsonData.out_of_stock_count).to.be.a(\"number\");\r",
              "    pm.expect(jsonData.total_inventory_value).to.be.a(\"number\");\r",
              "    pm.expect(jsonData.total_parts).to.be.a(\"number\");\r",
              "    pm.expect(jsonData.total_quantity).to.be.a(\"number\");\r",
              "\r",
              "    pm.expect(jsonData.low_stock_parts).to.be.an(\"array\");\r",
              "    pm.expect(jsonData.out_of_stock_parts).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "\r",
              "// Logic consistency\r",
              "pm.test(\"Count = length của array\", function () {\r",
              "    pm.expect(jsonData.low_stock_count).to.eql(jsonData.low_stock_parts.length);\r",
              "    pm.expect(jsonData.out_of_stock_count).to.eql(jsonData.out_of_stock_parts.length);\r",
              "});\r",
              "\r",
              "//Không có số âm\r",
              "pm.test(\"Không có giá trị âm\", function () {\r",
              "    pm.expect(jsonData.total_parts).to.be.at.least(0);\r",
              "    pm.expect(jsonData.total_quantity).to.be.at.least(0);\r",
              "    pm.expect(jsonData.total_inventory_value).to.be.at.least(0);\r",
              "});\r",
              "\r",
              "// Performance\r",
              "pm.test(\"Response time < 2s\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}{{url_prefix}}/inventory",
          "host": [
            "{{baseUrl}}{{url_prefix}}"
          ],
          "path": [
            "inventory"
          ]
        }
      },
      "response": []
