      "item": [
        {
          "name": "CREATE PROFILE",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// ===================== 1. STATUS =====================\r",
                  "pm.test(\"Status code is 200 or 201\", function () {\r",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);\r",
                  "});\r",
                  "\r",
                  "\r",
                  "// ===================== 2. PARSE =====================\r",
                  "let jsonData;\r",
                  "try {\r",
                  "    jsonData = pm.response.json();\r",
                  "} catch (e) {\r",
                  "    throw new Error(\"Response is not JSON\");\r",
                  "}\r",
                  "\r",
                  "\r",
                  "// ===================== 3. STRUCTURE =====================\r",
                  "pm.test(\"Response has profile object\", function () {\r",
                  "    pm.expect(jsonData).to.have.property(\"profile\");\r",
                  "});\r",
                  "\r",
                  "let profile = jsonData.profile;\r",
                  "\r",
                  "\r",
                  "// ===================== 4. FIELD VALIDATION =====================\r",
                  "pm.test(\"Profile contains required fields\", function () {\r",
                  "    pm.expect(profile).to.have.property(\"full_name\");\r",
                  "    pm.expect(profile).to.have.property(\"phone_number\");\r",
                  "    pm.expect(profile).to.have.property(\"address\");\r",
                  "    pm.expect(profile).to.have.property(\"vin_number\");\r",
                  "});\r",
                  "\r",
                  "\r",
                  "// ===================== 5. DATA VALIDATION =====================\r",
                  "let requestData = JSON.parse(pm.request.body.raw);\r",
                  "\r",
                  "pm.test(\"Full name matches request\", function () {\r",
                  "    pm.expect(profile.full_name).to.eql(requestData.full_name);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Phone matches request\", function () {\r",
                  "    pm.expect(profile.phone_number).to.eql(requestData.phone_number);\r",
                  "});\r",
                  "\r",
                  "\r",
                  "// ===================== 6. SECURITY =====================\r",
                  "pm.test(\"No password leaked\", function () {\r",
                  "    pm.expect(profile.password).to.be.undefined;\r",
                  "});\r",
                  "\r",
                  "\r",
                  "// ===================== 7. BUSINESS LOGIC =====================\r",
                  "pm.test(\"User ID exists\", function () {\r",
                  "    pm.expect(profile.user_id).to.exist;\r",
                  "});\r",
                  "\r",
                  "\r",
                  "// ===================== 8. SAVE DATA (FIX CHÍNH) =====================\r",
                  "pm.environment.set(\"phone_number\", profile.phone_number);\r",
                  "pm.environment.set(\"vin_number\", profile.vin_number);\r",
                  "\r",
                  "//  lưu user_id đúng\r",
                  "pm.environment.set(\"user_id\", profile.user_id);\r",
                  "\r",
                  "\r",
                  "// ===================== 9. PERFORMANCE =====================\r",
                  "pm.test(\"Response time < 2000ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});\r",
                  "\r",
                  "\r",
                  "// ===================== 10. CONTENT TYPE =====================\r",
                  "pm.test(\"Content-Type is JSON\", function () {\r",
                  "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
                  "});\r",
                  "\r",
                  "\r",
                  "// ===================== 11. DEBUG =====================\r",
                  "console.log(\"FULL RESPONSE:\", jsonData);\r",
                  "console.log(\"PROFILE:\", profile);\r",
                  "console.log(\"Saved user_id:\", pm.environment.get(\"user_id\"));\r",
                  "console.log(\"Token used:\", pm.environment.get(\"token\"));"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
