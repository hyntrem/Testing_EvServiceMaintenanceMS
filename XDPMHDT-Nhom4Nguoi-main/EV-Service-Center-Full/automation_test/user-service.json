        {
          "name": "REGISTER",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// ===================== 1. STATUS CODE =====================\r",
                  "// Kiểm tra request thành công (201 hoặc 200 tùy backend)\r",
                  "pm.test(\"Status code is 201 or 200\", function () {\r",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);\r",
                  "});\r",
                  "\r",
                  "\r",
                  "// ===================== 2. PARSE RESPONSE =====================\r",
                  "let jsonData;\r",
                  "try {\r",
                  "    jsonData = pm.response.json();\r",
                  "} catch (e) {\r",
                  "    pm.test(\"Response is valid JSON\", function () {\r",
                  "        throw new Error(\"Response is not JSON\");\r",
                  "    });\r",
                  "}\r",
                  "\r",
                  "\r",
                  "// ===================== 3. STRUCTURE VALIDATION (STATIC TESTING) =====================\r",
                  "// Kiểm tra response có field user\r",
                  "pm.test(\"Response has user object\", function () {\r",
                  "    pm.expect(jsonData).to.have.property(\"user\");\r",
                  "});\r",
                  "\r",
                  "// Kiểm tra user có email\r",
                  "pm.test(\"User contains email\", function () {\r",
                  "    pm.expect(jsonData.user).to.have.property(\"email\");\r",
                  "});\r",
                  "\r",
                  "\r",
                  "// ===================== 4. DATA VALIDATION =====================\r",
                  "// Kiểm tra email đúng với request gửi lên\r",
                  "pm.test(\"Email matches request\", function () {\r",
                  "    let requestData = JSON.parse(pm.request.body.raw);\r",
                  "    pm.expect(jsonData.user.email).to.eql(requestData.email);\r",
                  "});\r",
                  "\r",
                  "\r",
                  "// ===================== 5. SECURITY TEST =====================\r",
                  "// Đảm bảo không trả về password (bảo mật)\r",
                  "pm.test(\"Password is not returned\", function () {\r",
                  "    pm.expect(jsonData.user.password).to.be.undefined;\r",
                  "});\r",
                  "\r",
                  "\r",
                  "// ===================== 6. BUSINESS LOGIC TEST =====================\r",
                  "// Kiểm tra user_id tồn tại (nếu backend có)\r",
                  "pm.test(\"User ID exists\", function () {\r",
                  "    pm.expect(jsonData.user.id || jsonData.user.user_id).to.exist;\r",
                  "});\r",
                  "\r",
                  "\r",
                  "// ===================== 7. SAVE DATA (DYNAMIC TESTING) =====================\r",
                  "// Lưu email để dùng cho login sau\r",
                  "pm.environment.set(\"user_email\", jsonData.user.email);\r",
                  "\r",
                  "\r",
                  "// ===================== 8. PERFORMANCE TEST =====================\r",
                  "// Kiểm tra tốc độ phản hồi < 2s\r",
                  "pm.test(\"Response time is less than 2000ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});\r",
                  "\r",
                  "\r",
                  "// ===================== 9. CONTENT-TYPE CHECK =====================\r",
                  "pm.test(\"Content-Type is application/json\", function () {\r",
                  "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
                  "});\r",
                  "\r",
                  "\r",
                  "// ===================== 10. DEBUG (KHI CẦN) =====================\r",
                  "// In ra console để debug nếu lỗi\r",
                  "console.log(\"Response:\", jsonData);\r",
                  "\r",
                  "// login auto \r",
                  "pm.environment.set(\"user_email\", jsonData.user.email);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
