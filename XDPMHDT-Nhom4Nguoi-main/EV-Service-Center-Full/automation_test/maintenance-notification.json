{
  "info": {
    "name": "EV Service - Maintenance & Notification",
    "_postman_id": "c5bb2d3c-0000-0000-0000-000000000000",
    "description": "Collection cho maintenance-service và notification-service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Maintenance Service",
      "item": [
        {
          "name": "Create Maintenance Task (tạo maintenance request)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_admin}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/maintenance/tasks",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "maintenance",
                "tasks"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"booking_id\": 1,\n  \"technician_id\": 2\n}"
            },
            "description": "Admin tạo công việc bảo trì mới từ booking."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response has task object\", function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('task');",
                  "    pm.expect(json.task).to.have.property('id');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get My Maintenance Tasks (GET /api/maintenance)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_user}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/maintenance/my-tasks",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "maintenance",
                "my-tasks"
              ]
            },
            "description": "Lấy danh sách công việc bảo trì của user hiện tại."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is array\", function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update Maintenance Task Status (PUT /api/maintenance/{id})",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_user}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/maintenance/tasks/{{task_id}}/status",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "maintenance",
                "tasks",
                "{{task_id}}",
                "status"
              ],
              "variable": [
                {
                  "key": "task_id",
                  "value": "1",
                  "description": "ID task bảo trì cần cập nhật"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\"\n}"
            },
            "description": "Cập nhật trạng thái công việc bảo trì."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Task status updated\", function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('task');",
                  "    pm.expect(json.task.status).to.eql('in_progress');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Notification Service",
      "item": [
        {
          "name": "Get My Notifications (GET /api/notifications)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_user}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/notifications/my-notifications?unread_only=false",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "notifications",
                "my-notifications"
              ],
              "query": [
                {
                  "key": "unread_only",
                  "value": "false"
                }
              ]
            },
            "description": "Lấy danh sách thông báo của user hiện tại."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is array\", function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Create Notification (gửi notification)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Internal-Token",
                "value": "{{internal_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/internal/notifications/create",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "internal",
                "notifications",
                "create"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 1,\n  \"title\": \"Maintenance Scheduled\",\n  \"message\": \"Your EV maintenance has been scheduled.\",\n  \"notification_type\": \"maintenance\",\n  \"channel\": \"in_app\",\n  \"priority\": \"medium\",\n  \"related_entity_type\": \"maintenance_task\",\n  \"related_entity_id\": 1,\n  \"metadata\": {\n    \"booking_id\": 1,\n    \"task_id\": 1\n  }\n}"
            },
            "description": "Internal API để tạo notification (dùng X-Internal-Token)."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Notification created\", function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('notification');",
                  "    pm.expect(json.notification).to.have.property('id');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost"
    },
    {
      "key": "jwt_admin",
      "value": ""
    },
    {
      "key": "jwt_user",
      "value": ""
    },
    {
      "key": "internal_token",
      "value": ""
    }
  ]
}

