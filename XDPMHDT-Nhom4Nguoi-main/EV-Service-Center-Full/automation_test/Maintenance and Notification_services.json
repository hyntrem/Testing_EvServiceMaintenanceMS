              "name": "POST /internal/notifications/create (Missing Token)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "// 1. Kiểm tra Status Code (Quan trọng nhất)\r",
                      "pm.test(\"1. Trả về lỗi 404 hoặc 401\", () => {\r",
                      "    pm.expect(pm.response.code).to.be.oneOf([401, 404]);\r",
                      "});\r",
                      "\r",
                      "// 2. Kiểm tra nếu trả về HTML thay vì JSON (Trường hợp bạn vừa gặp)\r",
                      "const responseText = pm.response.text();\r",
                      "const isHtml = responseText.includes(\"<!doctype html>\") || responseText.includes(\"<html>\");\r",
                      "\r",
                      "pm.test(\"2. Kiểm tra định dạng phản hồi\", () => {\r",
                      "    if (isHtml) {\r",
                      "        pm.expect(responseText).to.include(\"Not Found\");\r",
                      "    } else {\r",
                      "        pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"json\");\r",
                      "    }\r",
                      "});\r",
                      "\r",
                      "// 3. Các test case phụ cho độ bền\r",
                      "pm.test(\"3. Thời gian phản hồi nhanh < 300ms\", () => {\r",
                      "    pm.expect(pm.response.responseTime).to.be.below(300);\r",
                      "});\r",
                      "\r",
                      "pm.test(\"4. Header Server không lộ thông tin\", () => {\r",
                      "    pm.expect(pm.response.headers.get(\"Server\")).to.not.include(\"Version\");\r",
                      "});\r",
                      "\r",
                      "pm.test(\"5. Không có dữ liệu nhạy cảm trong HTML/JSON\", () => {\r",
                      "    pm.expect(responseText).to.not.include(\"password\");\r",
                      "});\r",
                      "\r",
                      "// 6. Check lỗi Spelling (Gợi ý dựa trên nội dung HTML bạn nhận được)\r",
                      "pm.test(\"6. Kiểm tra gợi ý spelling trong response\", () => {\r",
                      "    if (isHtml) {\r",
                      "        pm.expect(responseText).to.include(\"check your spelling\");\r",
                      "    }\r",
                      "});\r",
                      "\r",
                      "// 7. Connection status\r",
                      "pm.test(\"7. Connection vẫn giữ ổn định\", () => {\r",
                      "    pm.expect(pm.response.headers.get(\"Connection\")).to.be.oneOf([\"keep-alive\", \"close\"]);\r",
                      "});\r",
                      "\r",
                      "// 8. Kiểm tra Content-Length\r",
                      "pm.test(\"8. Content-Length phải lớn hơn 0\", () => {\r",
                      "    pm.expect(parseInt(pm.response.headers.get(\"Content-Length\"))).to.be.above(0);\r",
                      "});\r",
                      "\r",
                      "// 9. Test case đặc biệt: URL không chứa ký tự lạ\r",
                      "pm.test(\"9. URL không chứa khoảng trắng\", () => {\r",
                      "    pm.expect(pm.request.url.toString()).to.not.include(\" \");\r",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
