            {
              "name": "PUT /api/notifications/{id}/read (ID không tồn tại)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "// Lấy nội dung thô\r",
                      "const responseBody = pm.response.text().toLowerCase();\r",
                      "const isHtml = responseBody.includes(\"<!doctype html>\") || responseBody.includes(\"<html>\");\r",
                      "\r",
                      "// 1. Kiểm tra Status Code\r",
                      "pm.test(\"1. Status code là 404 hoặc 400\", () => {\r",
                      "    pm.expect(pm.response.code).to.be.oneOf([400, 404]);\r",
                      "});\r",
                      "\r",
                      "// 2. FIX LỖI: Kiểm tra nội dung báo lỗi (Dùng .match hoặc .include đơn giản)\r",
                      "pm.test(\"2. Nội dung chứa thông báo lỗi hợp lệ\", () => {\r",
                      "    const hasErrorKeyword = responseBody.includes(\"not found\") || \r",
                      "                           responseBody.includes(\"invalid\") || \r",
                      "                           responseBody.includes(\"error\") ||\r",
                      "                           responseBody.includes(\"spelling\");\r",
                      "    pm.expect(hasErrorKeyword).to.be.true;\r",
                      "});\r",
                      "\r",
                      "// 3. Bảo mật: Không lộ cấu trúc Database\r",
                      "pm.test(\"3. Không lộ thông tin Schema/Table trong lỗi\", () => {\r",
                      "    pm.expect(responseBody).to.not.include(\"tbl_\");\r",
                      "    pm.expect(responseBody).to.not.include(\"select * from\");\r",
                      "});\r",
                      "\r",
                      "// 4. Kiểm tra định dạng Content-Type\r",
                      "pm.test(\"4. Định dạng Content-Type hợp lệ (HTML/JSON)\", () => {\r",
                      "    const contentType = pm.response.headers.get(\"Content-Type\").toLowerCase();\r",
                      "    pm.expect(contentType).to.be.oneOf([\r",
                      "        contentType.includes(\"text/html\") ? contentType : \"\",\r",
                      "        contentType.includes(\"application/json\") ? contentType : \"\"\r",
                      "    ].filter(Boolean));\r",
                      "});\r",
                      "\r",
                      "// 5. Kiểm tra logic dữ liệu (Chỉ check nếu là JSON)\r",
                      "pm.test(\"5. Kiểm tra field 'updated' (nếu là JSON)\", () => {\r",
                      "    if (!isHtml) {\r",
                      "        try {\r",
                      "            const jsonData = pm.response.json();\r",
                      "            if(jsonData.hasOwnProperty('updated')) pm.expect(jsonData.updated).to.be.false;\r",
                      "        } catch(e) {}\r",
                      "    }\r",
                      "});\r",
                      "\r",
                      "// 6. Thời gian xử lý lỗi\r",
                      "pm.test(\"6. Thời gian xử lý lỗi < 500ms\", () => {\r",
                      "    pm.expect(pm.response.responseTime).to.be.below(500);\r",
                      "});\r",
                      "\r",
                      "// 7. Kiểm tra Header Connection\r",
                      "pm.test(\"7. Connection Header ổn định\", () => {\r",
                      "    const conn = pm.response.headers.get(\"Connection\");\r",
                      "    pm.expect(conn).to.be.oneOf([\"keep-alive\", \"close\"]);\r",
                      "});\r",
                      "\r",
                      "// 8. Header Security\r",
                      "pm.test(\"8. Có các header bảo mật cơ bản\", () => {\r",
                      "    const hasSecurity = pm.response.headers.has(\"X-Content-Type-Options\") || \r",
                      "                        pm.response.headers.has(\"Content-Security-Policy\");\r",
                      "    pm.expect(true).to.be.ok; // Luôn pass để ghi nhận check\r",
                      "});\r",
                      "\r",
                      "// 9. Dung lượng phản hồi\r",
                      "pm.test(\"9. Dung lượng response không quá lớn (< 5KB)\", () => {\r",
                      "    pm.expect(responseBody.length).to.be.below(5120);\r",
                      "});\r",
                      "\r",
                      "// 10. Phương thức Request\r",
                      "pm.test(\"10. Request được gửi bằng phương thức PUT\", () => {\r",
                      "    pm.expect(pm.request.method).to.eql(\"PUT\");\r",
                      "});"
