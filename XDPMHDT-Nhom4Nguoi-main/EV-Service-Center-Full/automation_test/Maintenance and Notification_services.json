            {
              "name": "DELETE /api/notifications/{id} (ID sai định dạng)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "// Lấy dữ liệu phản hồi\r",
                      "const responseBody = pm.response.text();\r",
                      "const responseCode = pm.response.code;\r",
                      "const contentType = pm.response.headers.get(\"Content-Type\")?.toLowerCase() || \"\";\r",
                      "\r",
                      "// 1. Kiểm tra Status Code: Với ID sai định dạng, 400 Bad Request là chuẩn nhất\r",
                      "pm.test(\"1. Status code phải là 400 (hoặc 404 nếu không tìm thấy)\", () => {\r",
                      "    pm.expect(responseCode).to.be.oneOf([400, 404]);\r",
                      "});\r",
                      "\r",
                      "// 2. Kiểm tra Message lỗi sử dụng Regex (Không phân biệt hoa thường)\r",
                      "pm.test(\"2. Thông báo lỗi ID sai định dạng/Không tồn tại\", () => {\r",
                      "    // Kiểm tra xem body có chứa các từ khóa lỗi phổ biến không\r",
                      "    pm.expect(responseBody).to.match(/invalid|format|not found|error|malformed/i);\r",
                      "});\r",
                      "\r",
                      "// 3. Bảo mật: Chặn lộ dữ liệu nhạy cảm\r",
                      "pm.test(\"3. Body trả về không chứa dữ liệu người dùng\", () => {\r",
                      "    const sensitiveFields = ['\"user_id\":', '\"email\":', '\"message\":'];\r",
                      "    sensitiveFields.forEach(field => {\r",
                      "        pm.expect(responseBody).to.not.include(field);\r",
                      "    });\r",
                      "});\r",
                      "\r",
                      "// 4. Kiểm tra Header Content-Type\r",
                      "pm.test(\"4. Content-Type phải là JSON (để app dễ xử lý lỗi)\", () => {\r",
                      "    pm.expect(contentType).to.include(\"application/json\");\r",
                      "});\r",
                      "\r",
                      "// 5. Hiệu năng\r",
                      "pm.test(\"5. Phản hồi xử lý lỗi nhanh < 250ms\", () => {\r",
                      "    pm.expect(pm.response.responseTime).to.be.below(250);\r",
                      "});\r",
                      "\r",
                      "// 6. Kiểm tra cấu trúc lỗi JSON (Nếu API trả về JSON chuẩn)\r",
                      "pm.test(\"6. Cấu trúc JSON lỗi hợp lệ\", () => {\r",
                      "    if (contentType.includes(\"json\")) {\r",
                      "        const jsonData = pm.response.json();\r",
                      "        // Kiểm tra xem có trường 'message' hoặc 'error' không\r",
                      "        pm.expect(jsonData).to.satisfy((data) => {\r",
                      "            return data.message || data.error || data.errors;\r",
                      "        });\r",
                      "    }\r",
                      "});\r",
                      "\r",
                      "// 7. Kiểm tra tính toàn vẹn của phương thức\r",
                      "pm.test(\"7. Phương thức Request là DELETE\", () => {\r",
                      "    pm.expect(pm.request.method).to.eql(\"DELETE\");\r",
                      "});"
