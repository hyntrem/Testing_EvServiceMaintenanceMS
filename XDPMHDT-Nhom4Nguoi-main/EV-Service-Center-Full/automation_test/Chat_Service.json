    {
      "name": "Waiting Room",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function(){\r",
              "    pm.response.to.have.status(200)\r",
              "})\r",
              "let JsonData = pm.response.json();\r",
              "//Kiểm tra xem có trả về room không\r",
              "pm.test(\"Response body contains room\", function(){\r",
              "    pm.expect(JsonData).to.have.property(\"rooms\")\r",
              "    })\r",
              "//Check success\r",
              "pm.test(\"Check success\", function(){\r",
              "    pm.expect(JsonData.success).to.have.eql(true)    \r",
              "    })\r",
              "//Kiêmr tra trạng thái phòng chờ\r",
              "pm.test(\"Check status waiting\", function(){\r",
              "    if(JsonData.rooms.length > 0){ \r",
              "        JsonData.rooms.forEach((room, index) => {\r",
              "            pm.expect(room.status).to.have.eql(\"waiting\");\r",
              "        });\r",
              "    }else{\r",
              "        pm.expect.fail(\"No waiting rooms found!\");\r",
              "    }\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
