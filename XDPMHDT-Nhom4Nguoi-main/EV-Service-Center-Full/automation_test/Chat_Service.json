    {
      "name": "Chat Room Management",
      "item": [
        {
          "name": "Closed Room",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Parse JSON\r",
                  "let jsonData = pm.response.json();\r",
                  "\r",
                  "// Status code\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "//  success = true\r",
                  "pm.test(\"Success is true\", function () {\r",
                  "    pm.expect(jsonData.success).to.eql(true);\r",
                  "});\r",
                  "\r",
                  "// rooms là array\r",
                  "pm.test(\"Rooms is array\", function () {\r",
                  "    pm.expect(jsonData.rooms).to.be.an(\"array\");\r",
                  "});\r",
                  "\r",
                  "// Có ít nhất 1 room\r",
                  "pm.test(\"Rooms not empty\", function () {\r",
                  "    pm.expect(jsonData.rooms.length).to.be.above(0);\r",
                  "});\r",
                  "\r",
                  "// Lấy room đầu\r",
                  "let room = jsonData.rooms[0];\r",
                  "\r",
                  "//  status phải là closed\r",
                  "pm.test(\"Room status is closed\", function () {\r",
                  "    pm.expect(room.status).to.eql(\"closed\");\r",
                  "});\r",
                  "\r",
                  "// closed_at phải có giá trị (KHÔNG null)\r",
                  "pm.test(\"Closed_at must NOT be null\", function () {\r",
                  "    pm.expect(room.closed_at).to.not.eql(null);\r",
                  "});\r",
                  "\r",
                  "//  unread_count phải = 0\r",
                  "pm.test(\"Unread count must be 0 when closed\", function () {\r",
                  "    pm.expect(room.unread_count).to.eql(0);\r",
                  "});\r",
                  "\r",
                  "// phải có support xử lý\r",
                  "pm.test(\"Support user must exist\", function () {\r",
                  "    pm.expect(room.support_user_id).to.not.eql(null);\r",
                  "    pm.expect(room.support_user_name).to.not.eql(null);\r",
                  "});\r",
                  "\r",
                  "// support_role hợp lệ\r",
                  "pm.test(\"Support role hợp lệ\", function () {\r",
                  "    let roles = [\"admin\", \"staff\"];\r",
                  "    pm.expect(roles).to.include(room.support_role);\r",
                  "});\r",
                  "\r",
                  "//  thời gian hợp lệ (closed >= created)\r",
                  "pm.test(\"Closed time >= created time\", function () {\r",
                  "    let created = new Date(room.created_at);\r",
                  "    let closed = new Date(room.closed_at);\r",
                  "\r",
                  "    pm.expect(closed >= created).to.be.true;\r",
                  "});\r",
                  "\r",
                  "//response time\r",
                  "pm.test(\"Response time < 2s\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}{{url_prefix}}/rooms/closed",
              "host": [
                "{{baseUrl}}{{url_prefix}}"
              ],
              "path": [
                "rooms",
                "closed"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Waiting Room",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let jsonData = pm.response.json();\r",
                  "\r",
                  "//Status code\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "//success = true\r",
                  "pm.test(\"Success is true\", function () {\r",
                  "    pm.expect(jsonData.success).to.eql(true);\r",
                  "});\r",
                  "\r",
                  "//rooms là array\r",
                  "pm.test(\"Rooms is array\", function () {\r",
                  "    pm.expect(jsonData.rooms).to.be.an(\"array\");\r",
                  "});\r",
                  "\r",
                  "//rooms không rỗng\r",
                  "pm.test(\"Rooms is not empty\", function () {\r",
                  "    pm.expect(jsonData.rooms.length).to.be.above(0);\r",
                  "});\r",
                  "\r",
                  "//Loop từng room để test\r",
                  "jsonData.rooms.forEach((room, index) => {\r",
                  "\r",
                  "    //Check field tồn tại\r",
                  "    pm.test(`Room ${index} has all required fields`, function () {\r",
                  "        pm.expect(room).to.have.property(\"id\");\r",
                  "        pm.expect(room).to.have.property(\"status\");\r",
                  "        pm.expect(room).to.have.property(\"subject\");\r",
                  "        pm.expect(room).to.have.property(\"user_id\");\r",
                  "        pm.expect(room).to.have.property(\"user_name\");\r",
                  "        pm.expect(room).to.have.property(\"created_at\");\r",
                  "        pm.expect(room).to.have.property(\"updated_at\");\r",
                  "    });\r",
                  "\r",
                  "    //Check kiểu dữ liệu\r",
                  "    pm.test(`Room ${index} data types correct`, function () {\r",
                  "        pm.expect(room.id).to.be.a(\"number\");\r",
                  "        pm.expect(room.status).to.be.a(\"string\");\r",
                  "        pm.expect(room.subject).to.be.a(\"string\");\r",
                  "        pm.expect(room.user_id).to.be.a(\"number\");\r",
                  "        pm.expect(room.user_name).to.be.a(\"string\");\r",
                  "        pm.expect(room.unread_count).to.be.a(\"number\");\r",
                  "    });\r",
                  "\r",
                  "    //Check logic dữ liệu\r",
                  "    pm.test(`Room ${index} unread_count hợp lệ`, function () {\r",
                  "        pm.expect(room.unread_count).to.be.at.least(0);\r",
                  "    });\r",
                  "\r",
                  "    //Check status hợp lệ\r",
                  "    pm.test(`Room ${index} status hợp lệ`, function () {\r",
                  "        let validStatus = [\"waiting\", \"active\", \"closed\"];\r",
                  "        pm.expect(validStatus).to.include(room.status);\r",
                  "    });\r",
                  "\r",
                  "    //Check null fields\r",
                  "    pm.test(`Room ${index} closed_at hợp lệ`, function () {\r",
                  "        pm.expect(room.closed_at === null || typeof room.closed_at === \"string\").to.be.true;\r",
                  "    });\r",
                  "\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
