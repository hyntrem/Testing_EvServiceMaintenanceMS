    {
      "name": "Chat Room",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "//Lưu user_name vào biến\r",
              "let name = \"Le Quang My\";\r",
              "pm.environment.set(\"user_name\", name);\r",
              "//Tạo user_id ngẫu nhiên và lưu vào biến\r",
              "let id = Math.floor(Math.random() * 999999999)+1\r",
              "pm.environment.set(\"user_id\",id);\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function(){\r",
              "    pm.response.to.have.status(201)\r",
              "})\r",
              "let JsonData = pm.response.json();\r",
              "//Kiểm tra xem có trả về room không\r",
              "pm.test(\"Response body contains room\", function(){\r",
              "    pm.expect(JsonData.room).to.not.eql(null)\r",
              "    })\r",
              "//Check giá trị user_id\r",
              "pm.test(\"Check user_id\", function(){\r",
              "    pm.expect(JsonData.room.user_id).to.not.eql(null)\r",
              "})\r",
              "//Check giá trị user_name\r",
              "pm.test(\"Check user_name\", function(){\r",
              "    pm.expect(JsonData.room.user_name).to.not.eql(null)\r",
              "})\r",
              "//Check id \r",
              "pm.test(\"Check id\", function(){\r",
              "    pm.expect(JsonData.room.id).to.not.eql(null)\r",
              "})\r",
              "\r",
              "//lưu ID room\r",
              "let roomID = pm.response.json()\r",
              "pm.environment.set(\"Room_ID\",roomID.room.id)\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"user_id\": {{user_id}},\r\n  \"user_name\": \"{{user_name}}\"\r\n}",
          "options": {
