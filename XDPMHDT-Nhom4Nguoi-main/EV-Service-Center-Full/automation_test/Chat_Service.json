      "item": [
        {
          "name": "Chat Room",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "//Lưu user_name vào environment\r",
                  "const name = \"Le Quang My\";\r",
                  "pm.environment.set(\"user_name\", name);\r",
                  "\r",
                  "//Tạo user_id ngẫu nhiên và lưu vào environment\r",
                  "let id = Math.floor(Math.random() * 999999999)+1\r",
                  "pm.environment.set(\"user_id\",id);\r",
                  "\r",
                  "\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonData = pm.response.json();\r",
                  "//Kiểm tra status code\r",
                  "pm.test(\"Status code is 201\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "//Kiểm tra response time\r",
                  "pm.test(\"Response time is less than 200ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(200);\r",
                  "});\r",
                  "\r",
                  "//Kiểm tra success\r",
                  "pm.test(\"success is true\", function () {\r",
                  "    pm.expect(jsonData.success).to.be.true;\r",
                  "});\r",
                  "\r",
                  "//Kiểm tra room Object\r",
                  "pm.test(\"Room Object is not empty\", function () {\r",
                  "    pm.expect(jsonData.room).to.not.be.empty;\r",
                  "});\r",
                  "\r",
                  "//Kiểm tra các required fields\r",
                  "pm.test(\"Room ID is present\", function () {\r",
                  "    pm.expect(jsonData.room).to.have.property(\"closed_at\");\r",
                  "    pm.expect(jsonData.room).to.have.property(\"created_at\");\r",
                  "    pm.expect(jsonData.room).to.have.property(\"id\");\r",
                  "    pm.expect(jsonData.room).to.have.property(\"status\");\r",
                  "    pm.expect(jsonData.room).to.have.property(\"subject\");\r",
                  "    pm.expect(jsonData.room).to.have.property(\"support_role\");\r",
                  "    pm.expect(jsonData.room).to.have.property(\"support_user_id\");\r",
                  "    pm.expect(jsonData.room).to.have.property(\"support_user_name\");\r",
                  "    pm.expect(jsonData.room).to.have.property(\"unread_count\");\r",
                  "    pm.expect(jsonData.room).to.have.property(\"updated_at\");\r",
                  "    pm.expect(jsonData.room).to.have.property(\"user_id\");\r",
                  "    pm.expect(jsonData.room).to.have.property(\"user_name\");\r",
                  "});\r",
                  "\r",
                  "//Kiểm tra giá trị khi mới tạo\r",
                  "pm.test(\"New room has correct default values\", function(){\r",
                  "    pm.expect(jsonData.room.closed_at).to.be.null;\r",
                  "    pm.expect(jsonData.room.status).to.equal(\"waiting\");\r",
                  "    pm.expect(jsonData.room.subject).to.eql(\"Hỗ trợ khách hàng\");\r",
                  "    pm.expect(jsonData.room.support_role).to.be.null;\r",
                  "    pm.expect(jsonData.room.support_user_id).to.be.null;\r",
                  "    pm.expect(jsonData.room.support_user_name).to.be.null;\r",
                  "    pm.expect(jsonData.room.unread_count).to.equal(1);\r",
                  "})\r",
                  "\r",
                  "//Kiểm tra room_id hợp lệ\r",
                  "pm.test(\"Room ID is a valid number\", function(){\r",
                  "    pm.expect(jsonData.room.id).to.be.a('number');\r",
                  "    pm.expect(jsonData.room.id).to.be.above(0);\r",
                  "    })\r",
                  "\r",
                  "//Kiểm tra user_id hợp lệ\r",
                  "pm.test(\"User ID is a valid number\", function(){\r",
                  "    pm.expect(jsonData.room.user_id).to.be.a('number');\r",
                  "    pm.expect(jsonData.room.user_id).to.be.above(0);\r",
                  "    });\r",
                  "\r",
                  "//Kiểm tra user_name hợp lệ\r",
                  "pm.test(\"Check user_name\", function(){\r",
                  "    pm.expect(jsonData.room.user_name).to.be.a('string');\r",
                  "    pm.expect(jsonData.room.user_name).to.have.length.above(0);\r",
                  "})\r",
                  "\r",
                  "//Lưu room_id vào environments \r",
                  "pm.environment.set(\"Room_ID\", jsonData.room.id);\r",
                  "\r",
                  "//Kiểm tra created_at, updated_at"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
