    {
      "name": "Notification Service",
      "item": [
        {
          "name": "Create Test Notification (Internal)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "X-Internal-Token", "value": "{{internal_token}}"}
            ],
            "url": {
              "raw": "{{base_url}}/internal/notifications/create",
              "host": ["{{base_url}}"],
              "path": ["internal", "notifications", "create"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": {{user_id}},\n  \"title\": \"Test Notification\",\n  \"message\": \"This is a test notification for Postman testing\",\n  \"type\": \"info\"\n}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Extract user_id from jwt_user token",
                  "const jwtToken = pm.environment.get('jwt_user');",
                  "if (jwtToken) {",
                  "    // Decode JWT token (simple base64 decode of payload)",
                  "    const base64Url = jwtToken.split('.')[1];",
                  "    const base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');",
                  "    const jsonPayload = decodeURIComponent(atob(base64).split('').map(function(c) {",
                  "        return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);",
                  "    }).join(''));",
                  "    const payload = JSON.parse(jsonPayload);",
                  "    const userId = payload.sub;",
                  "    pm.environment.set('user_id', userId);",
                  "    console.log('✅ user_id extracted from jwt_user: ' + userId);",
                  "} else {",
                  "    console.error('❌ jwt_user token not found! Run Login first.');",
                  "}"
                ]
              }
            },
            {
            "listen": "test",
            "script": {
              "exec": [
                "pm.test(\"[NOTIF-CREATE-01] Status code is 201 Created\", () => {",
                "    pm.response.to.have.status(201);",
                "});",
                "",
                "pm.test(\"[NOTIF-CREATE-02] Response has notification object\", () => {",
                "    const json = pm.response.json();",
                "    pm.expect(json).to.have.property('notification');",
                "    pm.expect(json.notification).to.have.property('id');",
                "});",
                "",
                "// Auto-save notification_id for later tests",
                "if (pm.response.code === 201 && pm.response.json().notification) {",
                "    pm.environment.set('notification_id', pm.response.json().notification.id);",
                "    console.log('✅ Test notification created. notification_id saved: ' + pm.response.json().notification.id);",
                "}"
              ]
            }
          }]
