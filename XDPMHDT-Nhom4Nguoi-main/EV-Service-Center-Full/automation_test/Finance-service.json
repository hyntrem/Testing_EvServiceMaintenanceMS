  "item": [
    {
      "name": "Admin - Create Invoice",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "const res = pm.response.json();\r",
              "\r",
              "pm.test(\"Response has invoice object\", function () {\r",
              "    pm.expect(res).to.have.property(\"invoice\");\r",
              "    pm.expect(res.invoice).to.be.an(\"object\");\r",
              "});\r",
              "\r",
              "pm.test(\"Invoice has id\", function () {\r",
              "    pm.expect(res.invoice).to.have.property(\"id\");\r",
              "});\r",
              "\r",
              "pm.test(\"Invoice has booking_id\", function () {\r",
              "    pm.expect(res.invoice).to.have.property(\"booking_id\");\r",
              "});\r",
              "\r",
              "pm.test(\"Invoice has total_amount\", function () {\r",
              "    pm.expect(res.invoice).to.have.property(\"total_amount\");\r",
              "});\r",
              "\r",
              "pm.test(\"Invoice has status\", function () {\r",
              "    pm.expect(res.invoice).to.have.property(\"status\");\r",
              "});\r",
              "\r",
              "if (res.invoice && res.invoice.id) {\r",
              "    pm.environment.set(\"invoice_id\", res.invoice.id);\r",
              "}\r",
              "\r",
              "pm.test(\"Saved invoice_id to environment\", function () {\r",
              "    pm.expect(pm.environment.get(\"invoice_id\")).to.exist;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{admin_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_admin}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"booking_id\": {{booking_id}}\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url_finance}}/api/invoices/",
          "host": [
            "{{base_url_finance}}"
          ],
          "path": [
            "api",
            "invoices",
            ""
          ]
        }
      },
      "response": []
    },
