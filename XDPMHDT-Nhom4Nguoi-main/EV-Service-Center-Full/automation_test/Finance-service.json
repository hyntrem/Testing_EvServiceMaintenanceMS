    {
      "name": "Create Invoice - Success",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let res = pm.response.json();\r",
              "\r",
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "if (pm.response.code === 201) {\r",
              "    pm.test(\"Response has invoice object\", function () {\r",
              "        pm.expect(res).to.have.property(\"invoice\");\r",
              "        pm.expect(res.invoice).to.be.an(\"object\");\r",
              "    });\r",
              "\r",
              "    pm.test(\"Invoice has required fields\", function () {\r",
              "        pm.expect(res.invoice).to.have.property(\"id\");\r",
              "        pm.expect(res.invoice).to.have.property(\"booking_id\");\r",
              "        pm.expect(res.invoice).to.have.property(\"total_amount\");\r",
              "        pm.expect(res.invoice).to.have.property(\"status\");\r",
              "        pm.expect(res.invoice).to.have.property(\"items\");\r",
              "        pm.expect(res.invoice).to.have.property(\"user_id\");\r",
              "    });\r",
              "\r",
              "    pm.test(\"booking_id in response matches request\", function () {\r",
              "        let req = JSON.parse(pm.request.body.raw);\r",
              "        pm.expect(String(res.invoice.booking_id)).to.eql(String(req.booking_id));\r",
              "    });\r",
              "\r",
              "    pm.test(\"Invoice has items array\", function () {\r",
              "        pm.expect(res.invoice.items).to.be.an(\"array\");\r",
              "        pm.expect(res.invoice.items.length).to.be.greaterThan(1);\r",
              "    });\r",
              "\r",
              "    pm.test(\"Has service item\", function () {\r",
              "        const hasService = res.invoice.items.some(i => i.item_type === \"service\");\r",
              "        pm.expect(hasService).to.eql(true);\r",
              "    });\r",
              "\r",
              "    pm.test(\"Has part item\", function () {\r",
              "        const hasPart = res.invoice.items.some(i => i.item_type === \"part\");\r",
              "        pm.expect(hasPart).to.eql(true);\r",
              "    });\r",
              "\r",
              "    pm.test(\"Total amount equals sum of item subtotals\", function () {\r",
              "    const res = pm.response.json();\r",
              "    let sum = 0;\r",
              "    res.invoice.items.forEach(i => sum += Number(i.sub_total));\r",
              "    pm.expect(Number(res.invoice.total_amount)).to.eql(sum);\r",
              "    });\r",
              "\r",
              "    pm.environment.set(\"invoice_id\", res.invoice.id);\r",
              "    pm.environment.set(\"payment_amount\", res.invoice.total_amount);\r",
              "    pm.environment.set(\"invoice_status\", res.invoice.status);\r",
              "    pm.environment.set(\"user_id\", res.invoice.user_id);\r",
              "\r",
              "    const partItem = res.invoice.items.find(i => i.item_type === \"part\");\r",
              "    if (partItem) {\r",
              "        pm.environment.set(\"used_quantity\", partItem.quantity);\r",
              "        pm.environment.set(\"part_description\", partItem.description);\r",
              "    }\r",
              "\r",
              "    pm.test(\"invoice_id saved\", function () {\r",
              "        pm.expect(pm.environment.get(\"invoice_id\")).to.exist;\r",
              "    });\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
