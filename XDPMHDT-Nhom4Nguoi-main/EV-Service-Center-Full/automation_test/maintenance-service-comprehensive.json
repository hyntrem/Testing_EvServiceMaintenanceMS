    {
      "name": "Task 3 - Test Get Tasks",
      "item": [
        {
          "name": "Scenario 1: GET All Tasks (Admin)",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_admin}}"}],
            "url": {
              "raw": "{{base_url}}/api/maintenance/tasks",
              "host": ["{{base_url}}"],
              "path": ["api", "maintenance", "tasks"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "// TASK 3 - Scenario 1: GET list",
                "pm.test(\"[GET-LIST-01] Status code is 200 OK\", () => {",
                "    pm.response.to.have.status(200);",
                "});",
                "",
                "pm.test(\"[GET-LIST-02] Response is an array\", () => {",
                "    const json = pm.response.json();",
                "    pm.expect(json).to.be.an('array');",
                "});",
                "",
                "pm.test(\"[GET-LIST-03] Array contains task objects with required fields\", () => {",
                "    const json = pm.response.json();",
                "    if (json.length > 0) {",
                "        pm.expect(json[0]).to.have.property('task_id');",
                "        pm.expect(json[0]).to.have.property('status');",
                "        pm.expect(json[0]).to.have.property('booking_id');",
                "        pm.expect(json[0]).to.have.property('technician_id');",
                "    }",
                "});",
                "",
                "pm.test(\"[GET-LIST-04] Tasks are ordered by created_at desc\", () => {",
                "    const json = pm.response.json();",
                "    if (json.length > 1) {",
                "        const first = new Date(json[0].created_at);",
                "        const second = new Date(json[1].created_at);",
                "        pm.expect(first >= second).to.be.true;",
                "    }",
                "});",
                "",
                "// Save first task_id for later use",
                "if (pm.response.json().length > 0) {",
                "    pm.environment.set('task_id', pm.response.json()[0].task_id);",
                "    console.log('✅ task_id saved from list: ' + pm.response.json()[0].task_id);",
                "}",
                "",
                "pm.test(\"[GET-LIST-05] Response time < 1500ms\", () => {",
                "    pm.expect(pm.response.responseTime).to.be.below(1500);",
                "});"
              ]
            }
          }]
        },
