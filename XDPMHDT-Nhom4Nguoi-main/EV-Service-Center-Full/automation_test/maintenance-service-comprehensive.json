        {
          "name": "Scenario 4: Update task đã completed",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{jwt_admin}}"}
            ],
            "url": {
              "raw": "{{base_url}}/api/maintenance/tasks/{{completed_task_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["api", "maintenance", "tasks", "{{completed_task_id}}", "status"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"pending\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "// TASK 5 - Scenario 4: Update completed task",
                "// Note: Backend allows this, so we test it succeeds",
                "pm.test(\"[UPDATE-COMPLETED-01] Status code is 200 (allowed) or 400 (not allowed)\", () => {",
                "    pm.expect([200, 400]).to.include(pm.response.code);",
                "});",
                "",
                "if (pm.response.code === 200) {",
                "    pm.test(\"[UPDATE-COMPLETED-02] Task status can be changed from completed\", () => {",
                "        const json = pm.response.json();",
                "        pm.expect(json).to.have.property('task');",
                "    });",
                "} else {",
                "    pm.test(\"[UPDATE-COMPLETED-02] Cannot update completed task\", () => {",
                "        const json = pm.response.json();",
                "        pm.expect(json).to.have.property('error');",
                "    });",
                "}"
              ]
            }
          }]
        }
      ]
    },
