            "body": {
              "mode": "raw",
              "raw": "{\n  \"booking_id\": 99999,\n  \"technician_id\": 4\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "// TASK 2 - Scenario 3: Booking không tồn tại",
                "pm.test(\"[CREATE-BOOKING-NOT-FOUND-01] Status code is 400 or 404\", () => {",
                "    pm.expect([400, 404]).to.include(pm.response.code);",
                "});",
                "",
                "pm.test(\"[CREATE-BOOKING-NOT-FOUND-02] Error message indicates booking not found\", () => {",
                "    const json = pm.response.json();",
                "    pm.expect(json).to.have.property('error');",
                "    pm.expect(json.error.toLowerCase()).to.satisfy(msg => ",
                "        msg.includes('booking') || msg.includes('404') || msg.includes('not found')",
                "    );",
                "});",
                "",
                "pm.test(\"[CREATE-BOOKING-NOT-FOUND-03] No task created\", () => {",
                "    const json = pm.response.json();",
                "    pm.expect(json).to.not.have.property('task');",
                "});"
              ]
            }
          }]
        },
