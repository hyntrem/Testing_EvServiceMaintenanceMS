{
  "info": {
    "name": "Maintenance Service - Comprehensive Testing (Jira Sprint)",
    "_postman_id": "maintenance-comprehensive-2024",
    "description": "Complete test suite for Maintenance Service covering all CRUD operations with positive and negative test cases. Note: Notification endpoints use /my-notifications and /admin/all paths.",
