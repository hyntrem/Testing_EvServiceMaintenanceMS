    {
      "name": "Task 5 - Test Update Task Status",
      "item": [
        {
          "name": "Scenario 1: Update pending → in_progress",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{jwt_admin}}"}
            ],
            "url": {
              "raw": "{{base_url}}/api/maintenance/tasks/{{task_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["api", "maintenance", "tasks", "{{task_id}}", "status"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "// TASK 5 - Scenario 1: Update pending → in_progress",
                "pm.test(\"[UPDATE-STATUS-PROGRESS-01] Status code is 200 OK\", () => {",
                "    pm.response.to.have.status(200);",
                "});",
                "",
                "pm.test(\"[UPDATE-STATUS-PROGRESS-02] Response has success message\", () => {",
                "    const json = pm.response.json();",
                "    pm.expect(json).to.have.property('message');",
                "    pm.expect(json.message).to.include('thành công');",
                "});",
                "",
                "pm.test(\"[UPDATE-STATUS-PROGRESS-03] Task status updated to in_progress\", () => {",
                "    const json = pm.response.json();",
                "    pm.expect(json).to.have.property('task');",
                "    pm.expect(json.task.status).to.eql('in_progress');",
                "});",
                "",
                "pm.test(\"[UPDATE-STATUS-PROGRESS-04] Task ID unchanged\", () => {",
                "    const json = pm.response.json();",
                "    const requestedId = parseInt(pm.environment.get('task_id'));",
                "    pm.expect(json.task.task_id).to.eql(requestedId);",
                "});",
                "",
                "// Save in_progress task_id for next test",
                "if (pm.response.code === 200) {",
                "    pm.environment.set('in_progress_task_id', pm.response.json().task.task_id);",
                "}"
              ]
            }
          }]
