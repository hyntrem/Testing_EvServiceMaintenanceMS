        {
          "name": "Scenario 3: Booking không tồn tại",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{jwt_admin}}"}
            ],
            "url": {
              "raw": "{{base_url}}/api/maintenance/tasks",
              "host": ["{{base_url}}"],
