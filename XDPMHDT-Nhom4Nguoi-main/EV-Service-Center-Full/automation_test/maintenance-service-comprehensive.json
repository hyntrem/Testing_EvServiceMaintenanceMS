  "item": [
    {
      "name": "Setup - Authentication",
      "item": [
        {
          "name": "Login - Get Admin Token",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {
              "raw": "{{base_url}}/api/login",
              "host": ["{{base_url}}"],
              "path": ["api", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email_username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test(\"Login successful\", () => pm.response.to.have.status(200));",
                "pm.test(\"Has access token\", () => pm.expect(pm.response.json()).to.have.property('access_token'));",
                "if (pm.response.json().access_token) {",
                "    pm.environment.set('jwt_admin', pm.response.json().access_token);",
                "    console.log('✅ Admin token saved');",
                "}"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "Task 2 - Test Create Task",
      "item": [
        {
          "name": "Scenario 1: Create Task Success",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{jwt_admin}}"}
            ],
            "url": {
              "raw": "{{base_url}}/api/maintenance/tasks",
              "host": ["{{base_url}}"],
              "path": ["api", "maintenance", "tasks"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"booking_id\": 4,\n  \"technician_id\": 4\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "// TASK 2 - Scenario 1: Create task success",
                "pm.test(\"[CREATE-SUCCESS-01] Status code is 201 Created\", () => {",
                "    pm.response.to.have.status(201);",
                "});",
                "",
                "pm.test(\"[CREATE-SUCCESS-02] Response has success message\", () => {",
                "    const json = pm.response.json();",
                "    pm.expect(json).to.have.property('message');",
                "    pm.expect(json.message).to.include('thành công');",
                "});",
                "",
                "pm.test(\"[CREATE-SUCCESS-03] Task object has all required fields\", () => {",
                "    const json = pm.response.json();",
                "    pm.expect(json).to.have.property('task');",
                "    pm.expect(json.task).to.have.property('task_id');",
                "    pm.expect(json.task).to.have.property('booking_id');",
                "    pm.expect(json.task).to.have.property('user_id');",
                "    pm.expect(json.task).to.have.property('technician_id');",
                "    pm.expect(json.task).to.have.property('status');",
                "    pm.expect(json.task).to.have.property('vehicle_vin');",
                "    pm.expect(json.task).to.have.property('description');",
                "    pm.expect(json.task).to.have.property('created_at');",
                "});",
                "",
                "pm.test(\"[CREATE-SUCCESS-04] Task has correct initial status 'pending'\", () => {",
                "    const json = pm.response.json();",
                "    pm.expect(json.task.status).to.eql('pending');",
                "});",
                "",
                "pm.test(\"[CREATE-SUCCESS-05] Task has correct booking_id and technician_id\", () => {",
                "    const json = pm.response.json();",
                "    const requestBody = JSON.parse(pm.request.body.raw);",
                "    pm.expect(json.task.booking_id).to.eql(requestBody.booking_id);",
                "    pm.expect(json.task.technician_id).to.eql(requestBody.technician_id);",
                "});",
                "",
                "pm.test(\"[CREATE-SUCCESS-06] Default checklist items created\", () => {",
                "    const json = pm.response.json();",
                "    pm.expect(json.task).to.have.property('task_id');",
                "});",
                "",
                "// Auto-save task_id for later tests",
                "if (pm.response.code === 201 && pm.response.json().task) {",
                "    pm.environment.set('task_id', pm.response.json().task.task_id);",
                "    pm.environment.set('pending_task_id', pm.response.json().task.task_id);",
                "    console.log('✅ Task created. task_id saved: ' + pm.response.json().task.task_id);",
                "}",
                "",
                "pm.test(\"[CREATE-SUCCESS-07] Response time < 2000ms\", () => {",
                "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                "});"
              ]
            }
          }]
        },
        {
